# ============================================================================
# Multi Sand Sim - Unified Environment File (Backend + Frontend)
# ============================================================================
# This file is intended to be sourced for backend and read by frontend tooling.
# Backend uses: PORT, ALLOWED_ORIGINS, SECRET_KEY_BASE
# Frontend uses: PUBLIC_* variables (currently PUBLIC_WS_ENDPOINT)
# ============================================================================

# ----------------------------------------------------------------------------
# Global
# ----------------------------------------------------------------------------
APP_NAME=multi-sand-sim
APP_ENV=development
LOG_LEVEL=info
TZ=UTC

# ----------------------------------------------------------------------------
# Backend (Phoenix)
# ----------------------------------------------------------------------------
# Runtime binding
PORT=4000
BACKEND_HOST=0.0.0.0
BACKEND_PUBLIC_HOST=localhost
BACKEND_PUBLIC_SCHEME=http

# CORS + websocket origin checks
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Security
# Replace in production with a long random secret.
SECRET_KEY_BASE=dev_secret_key_base_change_me

# Optional Phoenix flags
PHX_SERVER=true
PHX_IPV6=false

# ----------------------------------------------------------------------------
# Frontend (SvelteKit / Vite)
# ----------------------------------------------------------------------------
# Public vars are exposed to the browser (safe values only)
PUBLIC_APP_NAME=Multi Sand Simulation
PUBLIC_APP_ENV=development
PUBLIC_WS_ENDPOINT=ws://localhost:4000/socket
PUBLIC_API_BASE_URL=http://localhost:4000

# Simulation/UI config
PUBLIC_CANVAS_WIDTH=800
PUBLIC_CANVAS_HEIGHT=600
PUBLIC_TICK_HZ=60
PUBLIC_SNAPSHOT_SECONDS=2
PUBLIC_SNAPSHOT_IDLE_RESYNC_MS=30000
PUBLIC_SNAPSHOT_IDLE_INPUT_GRACE_MS=1500
PUBLIC_BRUSH_RADIUS=7

# Dev server behavior
FRONTEND_HOST=0.0.0.0
FRONTEND_PORT=5173

# ----------------------------------------------------------------------------
# Monitoring / Debug (optional)
# ----------------------------------------------------------------------------
ENABLE_DEBUG_OVERLAY=false
ENABLE_VERBOSE_LOGS=false

# ----------------------------------------------------------------------------
# Production Override Template (copy values as needed)
# ----------------------------------------------------------------------------
# APP_ENV=production
# PORT=4000
# BACKEND_PUBLIC_HOST=api.your-domain.com
# BACKEND_PUBLIC_SCHEME=https
# ALLOWED_ORIGINS=https://app.your-domain.com
# SECRET_KEY_BASE=replace_with_a_long_random_secret_key_base
# PUBLIC_APP_ENV=production
# PUBLIC_WS_ENDPOINT=wss://api.your-domain.com/socket
# PUBLIC_API_BASE_URL=https://api.your-domain.com
# FRONTEND_PORT=4173
